// Dasolabs ERP — Prisma schema
// PostgreSQL 14+

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================
// ENUMS
// =============================================================

enum Role {
  ADMIN
  MANAGER
  COMMERCIAL
  CONSULTANT
  FINANCE
}

enum CompanyStatus {
  PROSPECT
  CLIENT
  PARTNER
  SUPPLIER
}

enum ContactStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum OfferStatus {
  DRAFT          // brouillon
  SENT           // envoyée
  NEGOTIATION    // en négociation
  WON            // gagnée
  LOST           // perdue
  CANCELLED      // annulée
}

enum OfferLineType {
  SERVICE
  LICENSE
  HARDWARE
  SUBCONTRACTING
  OTHER
}

enum BillingMilestoneStatus {
  PLANNED        // prévue (date connue, pas encore prête)
  READY          // prête à facturer (livrable validé, on peut émettre)
  INVOICED       // facturée (envoyée au client, en attente de paiement)
  TRANSMITTED    // transmise via Peppol (variante électronique d'INVOICED)
  PAID           // payée
  CANCELLED      // annulée
}

enum ProjectStatus {
  TO_START       // à démarrer
  ACTIVE         // actif
  ON_HOLD        // en pause
  COMPLETED      // terminé
  CANCELLED      // annulé
}

enum ActivityType {
  ANALYSIS
  DEVELOPMENT
  PROJECT_MANAGEMENT
  MEETING
  SUPPORT
  TRAINING
  COMMERCIAL
  ADMINISTRATIVE
  OTHER
}

enum TimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum PurchaseCategory {
  HARDWARE
  LICENSE
  SUBCONTRACTING
  TRAVEL
  TRAINING
  OTHER
}

enum PurchaseStatus {
  PLANNED
  ORDERED
  RECEIVED
  PAID
  CANCELLED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  OFFER_WON
  OFFER_LOST
  PROJECT_CREATED_FROM_OFFER
  TIMESHEET_SUBMITTED
  TIMESHEET_APPROVED
  TIMESHEET_REJECTED
  MILESTONE_STATUS_CHANGE
  CSV_IMPORT
  LOGIN
  LOGOUT
}

enum CostCenterKind {
  SALES
  LEAVE
  MEETING
  ADMIN
  TRAINING
  RND
  OTHER
}

// PROJECT  : forfait, tranches définies à la signature, complement -CN possible
// CONSULTING : T&M, profils consultants, facturation depuis timesheet validés
enum OfferMode {
  PROJECT
  CONSULTING
}

enum ProjectMode {
  PROJECT
  CONSULTING
}

enum MissionStatus {
  NEW
  QUALIFYING
  PRESENTING
  CONTRACTED
  LOST
  CANCELLED
}

enum CandidateStatus {
  ACTIVE
  ENGAGED
  UNAVAILABLE
  ARCHIVED
}

enum ApplicationStatus {
  PRESENTED
  INTERVIEW_SCHEDULED
  INTERVIEWED
  SHORTLISTED
  /// Proposition PDF envoyée au client (montant/dates figés). Passage
  /// intermédiaire avant SELECTED : quand le client valide la proposition,
  /// on passe à SELECTED qui déclenche la création automatique de Mission.
  OFFER_SENT
  SELECTED
  REJECTED
  WITHDRAWN
}

enum InterviewKind {
  PHONE
  VIDEO
  ON_SITE
  TECHNICAL
  HR
}

enum InterviewOutcome {
  PENDING
  PASSED
  FAILED
  CANCELLED
}

enum BillingFrequency {
  MONTHLY
  WEEKLY
  CUSTOM
}

// Statut d'exécution d'une Mission (consultance T&M, distinct du statut Projet forfait)
enum MissionExecutionStatus {
  PLANNED       // contractualisée mais pas encore commencée
  ACTIVE        // en cours
  EXTENDED      // prolongée
  COMPLETED     // terminée normalement
  CANCELLED     // annulée
  ON_HOLD       // suspension temporaire
}

// Suivi interne des consultants Dasolabs (≠ recrutement de candidats externes)
enum ConsultantReviewKind {
  ONBOARDING            // entretien d'arrivée
  CHECK_IN              // point régulier (mensuel/trimestriel)
  ANNUAL_REVIEW         // entretien annuel
  END_OF_MISSION        // bilan fin de mission
  PERFORMANCE           // performance / feedback
  CAREER                // évolution carrière
  OFFBOARDING           // entretien de départ
  OTHER_REVIEW
}

enum ConsultantReviewOutcome {
  SCHEDULED
  COMPLETED
  CANCELLED
  RESCHEDULED
}

// =============================================================
// CORE
// =============================================================

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  passwordHash      String
  firstName         String
  lastName          String
  role              Role      @default(CONSULTANT)
  active            Boolean   @default(true)
  // Profil personnel (consultant interne)
  photoUrl          String?
  phone             String?
  linkedinUrl       String?
  city              String?
  seniority         String?
  yearsExperience   Int?
  spokenLanguages   String[]  @default([])
  // Coûts internes
  dailyCost         Decimal?  @db.Decimal(10, 2)
  hourlyCost        Decimal?  @db.Decimal(10, 2)
  /// Taux journalier facturable au client (HTVA, EUR). Affiché sur le CV
  /// et utilisé comme suggestion par défaut lors de la présentation d'un
  /// consultant sur une demande de mission. Distinct de dailyCost qui est
  /// le coût interne Dasolabs.
  dailyRate         Decimal?  @db.Decimal(10, 2)
  weeklyCapacityH   Decimal   @default(38) @db.Decimal(5, 2)
  // Compétences (tags simples)
  skills            String[]  @default([])
  joinedAt          DateTime?
  leftAt            DateTime?
  // Lien si recruté depuis le vivier candidats (back-relation, défini sur Candidate)
  recruitedFromCandidate Candidate? @relation("CandidatePromotion")
  // Si l'utilisateur est un candidat à qui on a donné un accès portail
  candidateProfile       Candidate? @relation("CandidatePortal")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  ownedCompanies      Company[]          @relation("CompanyOwner")
  ownedContacts       Contact[]          @relation("ContactOwner")
  ownedOffers         Offer[]            @relation("OfferOwner")
  managedProjects     Project[]          @relation("ProjectManager")
  remainingUpdatesOnProjects Project[]   @relation("ProjectRemainingUpdater")
  salaryScenariosCreated CandidateSalaryScenario[] @relation("ScenarioCreator")
  cashflowSettingsUpdates CashflowSettings[] @relation("CashflowSettingsUpdater")
  recurringExpensesCreated RecurringExpense[] @relation("RecurringExpenseCreator")
  oneOffCashflowEntriesCreated OneOffCashflowEntry[] @relation("OneOffCashflowCreator")
  appLinksCreated     AppLink[]          @relation("AppLinkCreator")
  // Onboarding (l'instance de ce user, si présente)
  onboarding             Onboarding?      @relation("UserOnboarding")
  onboardingsCreated     Onboarding[]     @relation("OnboardingCreator")
  onboardingItemsOwned   OnboardingItem[] @relation("OnboardingItemOwner")
  onboardingItemsDone    OnboardingItem[] @relation("OnboardingItemDoneBy")
  // Documents
  documentsUploaded      Document[]       @relation("DocumentUploader")
  documentsAsConsultant  Document[]       @relation("DocumentConsultant")
  projectMemberships  ProjectMember[]
  timesheetEntries    TimesheetEntry[]   @relation("TimesheetUser")
  validatedTimesheets TimesheetEntry[]   @relation("TimesheetValidator")
  planningEntries     PlanningEntry[]
  purchasesCreated    Purchase[]         @relation("PurchaseCreator")
  attachmentsUploaded Attachment[]       @relation("AttachmentUploader")
  auditLogs           ActivityLog[]      @relation("ActivityLogActor")
  contactInteractions ContactInteraction[]
  ownedMissions       MissionRequest[]   @relation("MissionOwner")
  ownedCandidates     Candidate[]        @relation("CandidateOwner")
  // Propositions consultants dont je suis owner (préparateur du dossier)
  ownedProposals      MissionProposal[]  @relation("ProposalOwner")
  /// Expériences professionnelles du consultant interne (miroir de
  /// CandidateExperience). Alimentées via /users/[id] par un admin/manager,
  /// ou via /me par l'utilisateur lui-même. Affichées sur le PDF de
  /// proposition consultant page 2.
  experiences         UserExperience[]
  // Intégration bancaire — connexions créées par ce user + réconciliations
  bankConnections     BankConnection[]      @relation("BankConnectionCreator")
  bankReconciliations BankTransaction[]     @relation("BankReconciler")
  // Prospection outbound (chasseuse de têtes)
  outreachInteractions OutreachInteraction[] @relation("OutreachOwner")
  outreachTemplates    OutreachTemplate[]    @relation("OutreachTemplateCreator")
  /// Type de contrat de ce consultant chez Dasolabs. Idem Candidate.contractType.
  contractType         ContractType?
  /// Paie configurée pour ce consultant interne (si contractType=EMPLOYEE).
  payrollEmployee      PayrollEmployee? @relation("PayrollFromUser")
  // Missions T&M exécutées par ce consultant (User interne)
  consultantMissions  Mission[]          @relation("MissionConsultant")
  // Présentations sur des demandes de mission (consultant interne proposé au client)
  missionApplications MissionApplication[] @relation("UserApplications")
  // Entretiens internes (suivi consultant) : "subject" = celui dont on parle
  reviewsAsSubject    ConsultantReview[] @relation("ReviewSubject")
  reviewsConducted    ConsultantReview[] @relation("ReviewConductor")
  // Surcharges fines de permissions au-dessus du rôle/groupe
  permissionOverrides UserPermissionOverride[]
  // Groupe d'accès — indépendant du rôle (ex: un consultant peut être Admin)
  accessGroupId       String?
  accessGroup         AccessGroup? @relation(fields: [accessGroupId], references: [id], onDelete: SetNull)
  // Notes de frais (test feature)
  expenseReports      ExpenseReport[]      @relation("ExpenseReportUser")
  expenseReportsApproved ExpenseReport[]   @relation("ExpenseReportApprover")
  // Arrêts maladie déclarés par le consultant (certif joint, période)
  sickLeaves          SickLeave[]           @relation("UserSickLeaves")
  // Demandes de congés + solde annuel (en jours ouvrés)
  leaveRequests       LeaveRequest[]        @relation("UserLeaveRequests")
  leaveApprovals      LeaveRequest[]        @relation("LeaveRequestApprover")
  /// Quota annuel de jours de congé LÉGAUX (défaut 20 pour la Belgique — 4
  /// semaines légales). Modifiable individuellement (ancienneté, temps partiel).
  annualLeaveDays     Int                   @default(20)
  /// Quota annuel de RTT (Réduction du Temps de Travail). Défaut 12.
  rttDays             Int                   @default(12)
  /// Soldes par année et par catégorie — alimentés par le bouton "Ajouter
  /// congés nouvelle année" qui reporte le reste en CARRIED_OVER.
  leaveBalances       LeaveBalance[]        @relation("UserLeaveBalances")
  // CRM pipeline (test feature)
  opportunities       Opportunity[]         @relation("OpportunityOwner")
  opportunityActivities OpportunityActivity[] @relation("OpportunityActivityUser")
  // Factures fournisseurs (mirror Skwarel — test feature)
  supplierInvoicesCreated SupplierInvoice[] @relation("SupplierInvoiceCreator")
  // Tests techniques (évaluation candidat/consultant)
  testAssignments         TestAssignment[]  @relation("TestAssigneeUser")
  testAssignmentsCreated  TestAssignment[]  @relation("TestAssignmentCreator")
}

// =============================================================
// SERVICE PROFILES — taux standards utilisés en chiffrage offre
// =============================================================

model ServiceProfile {
  id             String   @id @default(cuid())
  name           String   // ex: "Senior Developer"
  description    String?
  active         Boolean  @default(true)
  // Coûts internes par défaut (peuvent être override par ligne)
  hourlyCost     Decimal  @db.Decimal(10, 2)
  dailyCost      Decimal  @db.Decimal(10, 2)
  // Prix de vente standards
  hourlySell     Decimal  @db.Decimal(10, 2)
  dailySell      Decimal  @db.Decimal(10, 2)
  offerLines     OfferLine[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// =============================================================
// COST CENTERS — temps non-projet (sales, congé, meeting interne…)
// =============================================================

model CostCenter {
  id              String         @id @default(cuid())
  code            String         @unique          // SALES, LEAVE, MTG…
  name            String
  kind            CostCenterKind @default(OTHER)
  active          Boolean        @default(true)
  // Si true : compte comme productif (visible dans capacité), sinon non
  countsAsBillable Boolean       @default(false)
  description     String?
  timesheetEntries TimesheetEntry[]
  planningEntries  PlanningEntry[]
  expenseReports   ExpenseReport[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

// =============================================================
// COMPANIES & CONTACTS
// =============================================================

model Company {
  id          String        @id @default(cuid())
  name        String
  vatNumber   String?       @unique          // BCE / TVA
  website     String?
  sector      String?
  size        String?
  status      CompanyStatus @default(PROSPECT)
  source      String?
  // Adresse
  street      String?
  city        String?
  postalCode  String?
  country     String?
  notes       String?
  ownerId     String?
  owner       User?         @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  contacts    Contact[]
  /// Contacts rattachés à cette société via la liaison N:N (un même
  /// contact peut être rattaché à plusieurs sociétés). Le champ historique
  /// Contact.companyId reste la « société principale » du contact.
  contactLinks ContactCompany[]
  offers      Offer[]
  projects    Project[]
  purchases   Purchase[]    @relation("CompanyAsSupplier")
  attachments Attachment[]  @relation("CompanyAttachments")
  missions    MissionRequest[]
  // Missions T&M exécutées chez ce client (consultant placé)
  executedMissions Mission[] @relation("MissionCompany")
  // Cas où cette société est l'intermédiaire / société de portage
  intermediaryRequests   MissionRequest[] @relation("MissionRequestIntermediary")
  intermediaryMissions   Mission[]        @relation("MissionExecIntermediary")
  // Tranches de facturation rattachées directement (sans offer/project)
  directBillingMilestones BillingMilestone[] @relation("DirectMilestoneCompany")
  // CRM pipeline (test feature)
  opportunities Opportunity[]              @relation("CompanyOpportunities")
  // Factures fournisseurs reçues de cette société (test feature)
  supplierInvoicesIssued SupplierInvoice[] @relation("CompanySupplierInvoices")
  // Documents rattachés à cette entreprise (contrats, NDAs, ...)
  documents              Document[]        @relation("DocumentCompany")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([name])
  @@index([status])
}

model Contact {
  id           String        @id @default(cuid())
  firstName    String
  lastName     String
  email        String?
  phone        String?
  jobTitle     String?
  status       ContactStatus @default(ACTIVE)
  notes        String?
  tags         String[]      @default([])
  /// Société « principale » du contact (mise en avant sur la fiche
  /// contact). Reste par rétro-compatibilité, mais un contact peut être
  /// rattaché à d'autres sociétés via companyLinks.
  companyId    String?
  company      Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  /// Rattachements N:N vers d'autres sociétés avec rôle par lien.
  /// Le lien marqué isPrimary=true correspond à companyId.
  companyLinks ContactCompany[]
  ownerId      String?
  owner        User?         @relation("ContactOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  interactions ContactInteraction[]
  // Liaisons
  offers       OfferContact[]
  projects     ProjectContact[]
  missions     MissionRequest[] @relation("MissionContact")
  // Contact côté société de portage / intermédiaire
  intermediaryRequests MissionRequest[] @relation("MissionRequestIntermediaryContact")
  intermediaryMissions Mission[]        @relation("MissionExecIntermediaryContact")
  // CRM
  opportunities Opportunity[]  @relation("ContactOpportunities")
  // Interactions de prospection (chasseuse de têtes contacte un décideur)
  outreachInteractions OutreachInteraction[] @relation("ContactOutreach")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([lastName, firstName])
  @@index([companyId])
}

/// Liaison N:N entre un Contact et une Company : un contact peut être
/// rattaché à plusieurs sociétés avec un rôle différent par entreprise.
///
/// Invariants applicatifs :
///  - Le lien isPrimary=true correspond au Contact.companyId (rétro-compat).
///  - Un seul lien isPrimary=true par contact (géré côté server actions ;
///    Prisma ne supporte pas les unique partial indexes en déclaratif).
///  - À la suppression d'une des deux entités, le lien est cascade-supprimé.
model ContactCompany {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  /// Rôle / fonction du contact dans CETTE société (peut différer du
  /// Contact.jobTitle qui est le rôle « principal »).
  jobTitle  String?
  /// True pour la société principale (= Contact.companyId).
  isPrimary Boolean  @default(false)
  notes     String?
  createdAt DateTime @default(now())

  @@unique([contactId, companyId])
  @@index([companyId])
  @@index([contactId, isPrimary])
}

model ContactInteraction {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  kind      String   // email, call, meeting, note...
  subject   String
  body      String?
  occurredAt DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([contactId, occurredAt])
}

// =============================================================
// OFFERS
// =============================================================

model Offer {
  id                 String              @id @default(cuid())
  reference          String              @unique
  title              String
  mode               OfferMode           @default(PROJECT)
  status             OfferStatus         @default(DRAFT)
  /// Stage CRM affiché dans le kanban. Distinct du status métier car le
  /// kanban a plus de granularité (NEW/QUALIFIED tous deux mappés vers DRAFT
  /// côté statut, mais on veut pouvoir les distinguer visuellement).
  crmStage           String              @default("NEW")
  /// Taux de TVA applicable à toute l'offre (uniforme, pas par ligne).
  /// 21 = Belgique standard, 0 = client export ou exonéré, 6/12 = taux réduits.
  /// Hérité à la création du projet et utilisé pour calculer le TVAC du cashflow.
  vatRate            Decimal             @default(21) @db.Decimal(5, 2)
  probability        Int                 @default(50)
  description        String?
  comments           String?

  companyId          String
  company            Company             @relation(fields: [companyId], references: [id], onDelete: Restrict)
  contacts           OfferContact[]

  // Compléments d'offre — forme une chaîne père/enfants
  parentOfferId      String?
  parentOffer        Offer?              @relation("OfferComplements", fields: [parentOfferId], references: [id], onDelete: SetNull)
  complements        Offer[]             @relation("OfferComplements")

  // Versioning : V2, V3... d'une offre envoyée que l'on souhaite remettre en chantier.
  // L'ancienne version garde tous ses statuts/audit, mais devient lecture seule
  // (et son champ supersededById pointe vers la nouvelle).
  version            Int                 @default(1)
  previousVersionId  String?             @unique
  previousVersion    Offer?              @relation("OfferVersion", fields: [previousVersionId], references: [id], onDelete: SetNull)
  nextVersion        Offer?              @relation("OfferVersion")

  // Mode CONSULTING : rattachement à une demande de mission
  missionRequestId   String?
  missionRequest     MissionRequest?     @relation(fields: [missionRequestId], references: [id], onDelete: SetNull)
  // Application (candidat) sélectionnée pour cette offre Consulting
  applicationId      String?             @unique
  application        MissionApplication? @relation("OfferApplication", fields: [applicationId], references: [id], onDelete: SetNull)

  ownerId            String?
  owner              User?               @relation("OfferOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  // Dates clés
  sentAt             DateTime?
  expectedDecisionAt DateTime?
  closedAt           DateTime?

  // Cache calculé (totaux)
  totalSell          Decimal             @default(0) @db.Decimal(12, 2)
  totalCost          Decimal             @default(0) @db.Decimal(12, 2)
  marginAmount       Decimal             @default(0) @db.Decimal(12, 2)
  marginPct          Decimal             @default(0) @db.Decimal(6, 3)

  lines              OfferLine[]
  options            OfferOption[]
  milestones         BillingMilestone[]
  attachments        Attachment[]        @relation("OfferAttachments")
  project            Project?
  // Documents rattachés à cette offre (proposition signée, annexes...)
  documents          Document[]          @relation("DocumentOffer")

  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([companyId])
  @@index([status])
}

model OfferContact {
  offerId   String
  contactId String
  offer     Offer   @relation(fields: [offerId], references: [id], onDelete: Cascade)
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([offerId, contactId])
}

/// Option d'une offre — bloc nommé contenant des lignes (services + matériel)
/// proposées en supplément du devis principal. Affichées en page 2bis du PDF.
model OfferOption {
  id          String   @id @default(cuid())
  offerId     String
  offer       Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  position    Int      @default(0)
  name        String                              // ex: "Hébergement 1 an"
  description String?
  /// Cache des totaux de l'option (somme des lignes rattachées)
  totalSell   Decimal  @default(0) @db.Decimal(12, 2)
  totalCost   Decimal  @default(0) @db.Decimal(12, 2)
  lines       OfferLine[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([offerId, position])
}

model OfferLine {
  id              String        @id @default(cuid())
  offerId         String
  offer           Offer         @relation(fields: [offerId], references: [id], onDelete: Cascade)
  /// Si renseigné, la ligne appartient à une option (et n'est PAS dans le total
  /// principal du devis). Sinon, ligne du devis de base.
  optionId        String?
  option          OfferOption?  @relation(fields: [optionId], references: [id], onDelete: Cascade)
  position        Int           @default(0)
  description     String
  type            OfferLineType @default(SERVICE)
  // Pour les lignes SERVICE : profil applicable (cout & prix de vente standards)
  profileId       String?
  profile         ServiceProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  // Pour les lignes "OTHER" : marge directe en %
  marginPctInput  Decimal?      @db.Decimal(5, 2)
  quantity        Decimal       @db.Decimal(10, 2)
  unit            String        @default("unit")  // unit, hour, day, license...
  unitSellPrice   Decimal       @db.Decimal(12, 2)
  unitCost        Decimal       @default(0) @db.Decimal(12, 2)
  discountPct     Decimal       @default(0) @db.Decimal(5, 2)

  // Cache calculé
  totalSell       Decimal       @default(0) @db.Decimal(12, 2)
  totalCost       Decimal       @default(0) @db.Decimal(12, 2)
  marginAmount    Decimal       @default(0) @db.Decimal(12, 2)
  marginPct       Decimal       @default(0) @db.Decimal(6, 3)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([offerId, position])
}

model BillingMilestone {
  id          String                  @id @default(cuid())
  offerId     String?
  offer       Offer?                  @relation(fields: [offerId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project?                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // Tranche T&M générée pour une mission consultance (mensuelle)
  missionId   String?
  mission     Mission?                @relation(fields: [missionId], references: [id], onDelete: Cascade)
  /// Lien direct vers une Company (utile pour les milestones standalone non
  /// rattachés à un offer/project/mission, par ex. facturation libre)
  companyId   String?
  company     Company?                @relation("DirectMilestoneCompany", fields: [companyId], references: [id], onDelete: SetNull)
  /// Snapshot du taux journalier au moment de la création/maj de la tranche.
  /// Permet de ne PAS recalculer les tranches passées si le rate de la mission
  /// change plus tard.
  appliedDailyRate Decimal?           @db.Decimal(10, 2)
  label       String
  // Soit pourcentage, soit montant fixe — on stocke les deux pour traçabilité
  percentage  Decimal?                @db.Decimal(5, 2)
  amount      Decimal                 @db.Decimal(12, 2)   // HTVA
  expectedAt  DateTime?
  trigger     String?                 // condition de déclenchement
  status      BillingMilestoneStatus  @default(PLANNED)
  comment     String?
  transmittedAt DateTime?
  paidAt        DateTime?
  // Transactions bancaires rapprochées avec cette tranche (recette client)
  bankMatches BankTransaction[]          @relation("BankMatchMilestone")
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@index([status, expectedAt])
  @@index([projectId])
  @@index([offerId])
  @@index([missionId])
}

// =============================================================
// PROJECTS
// =============================================================

model Project {
  id                 String         @id @default(cuid())
  reference          String         @unique
  name               String
  mode               ProjectMode    @default(PROJECT)
  // Pour CONSULTING : facturation périodique (mensuelle par défaut)
  billingFrequency   BillingFrequency? @default(MONTHLY)
  status             ProjectStatus  @default(TO_START)
  /// Stage CRM dans le kanban (WON par défaut puisqu'un projet est déjà signé).
  /// Permet d'afficher un projet annulé en CANCELLED sans changer son status métier.
  crmStage           String         @default("WON")
  /// Taux de TVA applicable au projet (hérité de l'offre à la création).
  /// 21 = Belgique standard, 0 = client export/exonéré. Utilisé par cashflow.
  vatRate            Decimal        @default(21) @db.Decimal(5, 2)
  description        String?
  notes              String?
  risks              String?

  companyId          String
  company            Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)

  offerId            String?        @unique
  sourceOffer        Offer?         @relation(fields: [offerId], references: [id], onDelete: SetNull)

  managerId          String?
  manager            User?          @relation("ProjectManager", fields: [managerId], references: [id], onDelete: SetNull)

  contacts           ProjectContact[]
  members            ProjectMember[]

  // Dates
  plannedStart       DateTime?
  plannedEnd         DateTime?
  actualStart        DateTime?
  actualEnd          DateTime?

  // Budgets
  budgetSell         Decimal        @default(0) @db.Decimal(12, 2)
  budgetCost         Decimal        @default(0) @db.Decimal(12, 2)
  budgetTimeH        Decimal        @default(0) @db.Decimal(8, 2)

  // Cache (recalculé)
  actualTimeH        Decimal        @default(0) @db.Decimal(10, 2)
  actualTimeCost     Decimal        @default(0) @db.Decimal(12, 2)
  actualPurchaseCost Decimal        @default(0) @db.Decimal(12, 2)
  marginEstimated    Decimal        @default(0) @db.Decimal(12, 2)
  marginActual       Decimal        @default(0) @db.Decimal(12, 2)
  progressPct        Decimal        @default(0) @db.Decimal(5, 2)

  // Reste à faire saisi manuellement par l'équipe (heures restantes pour terminer)
  remainingTimeH     Decimal        @default(0) @db.Decimal(8, 2)
  remainingUpdatedAt DateTime?
  remainingUpdatedById String?
  remainingUpdatedBy User?          @relation("ProjectRemainingUpdater", fields: [remainingUpdatedById], references: [id], onDelete: SetNull)

  milestones         BillingMilestone[]
  timesheetEntries   TimesheetEntry[]
  purchases          Purchase[]
  planningEntries    PlanningEntry[]
  attachments        Attachment[]   @relation("ProjectAttachments")
  reviews            ConsultantReview[] @relation("ProjectReviews")
  expenseReports     ExpenseReport[] @relation("ProjectExpenseReports")
  // Documents rattachés au projet (livrables signés, spécifications, ...)
  documents          Document[]     @relation("DocumentProject")

  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([companyId])
  @@index([status])
}

model ProjectContact {
  projectId String
  contactId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([projectId, contactId])
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  roleLabel String?  // ex: "Lead developer", "PM"
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([projectId, userId])
}

// =============================================================
// TIMESHEETS
// =============================================================

model TimesheetEntry {
  id              String          @id @default(cuid())
  userId          String
  user            User            @relation("TimesheetUser", fields: [userId], references: [id], onDelete: Cascade)
  // Une entrée timesheet vise EXACTEMENT UNE cible : projet, mission, ou centre de coût
  projectId       String?
  project         Project?        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  missionId       String?
  mission         Mission?        @relation(fields: [missionId], references: [id], onDelete: Cascade)
  costCenterId    String?
  costCenter      CostCenter?     @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  date            DateTime        @db.Date
  hours           Decimal         @db.Decimal(5, 2)
  activityType    ActivityType    @default(DEVELOPMENT)
  description     String?
  status          TimesheetStatus @default(DRAFT)
  validatorId     String?
  validator       User?           @relation("TimesheetValidator", fields: [validatorId], references: [id], onDelete: SetNull)
  validationNote  String?
  validatedAt     DateTime?
  // Cache coût (heures × hourlyCost user au moment de la validation)
  computedCost    Decimal?        @db.Decimal(12, 2)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([userId, date])
  @@index([projectId, date])
  @@index([status])
}

// =============================================================
// PURCHASES
// =============================================================

model Purchase {
  id            String           @id @default(cuid())
  projectId     String
  project       Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  supplierId    String?
  supplier      Company?         @relation("CompanyAsSupplier", fields: [supplierId], references: [id], onDelete: SetNull)
  description   String
  category      PurchaseCategory @default(OTHER)
  amount        Decimal          @db.Decimal(12, 2)  // HTVA
  vatRate       Decimal          @default(21) @db.Decimal(5, 2)
  vatAmount     Decimal          @default(0) @db.Decimal(12, 2)
  /// Override manuel du taux de déduction TVA (0.0 à 1.0). Par défaut, la règle
  /// belge déduite de la category s'applique. Mets 1.0 sur une voiture 100 %
  /// pro (avec carnet de bord) ou 0 sur un truc non déductible.
  vatDeductibleRateOverride Decimal? @db.Decimal(5, 2)
  purchaseDate  DateTime         @db.Date
  status        PurchaseStatus   @default(PLANNED)
  comment       String?
  attachments   Attachment[]     @relation("PurchaseAttachments")
  createdById   String?
  createdBy     User?            @relation("PurchaseCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([projectId])
  @@index([status])
}

// =============================================================
// PLANNING
// =============================================================

model PlanningEntry {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Cible UNIQUE : projet (forfait), mission (T&M), ou centre de coût (interne)
  projectId    String?
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  missionId    String?
  mission      Mission?     @relation(fields: [missionId], references: [id], onDelete: Cascade)
  costCenterId String?
  costCenter   CostCenter?  @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  startDate    DateTime     @db.Date
  endDate      DateTime     @db.Date
  // Soit hoursPerDay, soit pct (0..100)
  hoursPerDay  Decimal?     @db.Decimal(5, 2)
  loadPct      Decimal?     @db.Decimal(5, 2)
  activityType ActivityType @default(DEVELOPMENT)
  comment      String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([userId, startDate])
  @@index([projectId, startDate])
}

// =============================================================
// ATTACHMENTS (metadata only — fichiers stockés sur disque/S3)
// =============================================================

model Attachment {
  id          String   @id @default(cuid())
  filename    String
  mimeType    String
  sizeBytes   Int
  storagePath String
  uploadedById String?
  uploadedBy   User?    @relation("AttachmentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  // Polymorphisme léger via relations optionnelles
  companyId   String?
  company     Company? @relation("CompanyAttachments", fields: [companyId], references: [id], onDelete: Cascade)
  offerId     String?
  offer       Offer?   @relation("OfferAttachments", fields: [offerId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project? @relation("ProjectAttachments", fields: [projectId], references: [id], onDelete: Cascade)
  purchaseId  String?
  purchase    Purchase? @relation("PurchaseAttachments", fields: [purchaseId], references: [id], onDelete: Cascade)
  candidateId String?
  candidate   Candidate? @relation("CandidateAttachments", fields: [candidateId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

// =============================================================
// AUDIT TRAIL
// =============================================================

model ActivityLog {
  id         String      @id @default(cuid())
  actorId    String?
  actor      User?       @relation("ActivityLogActor", fields: [actorId], references: [id], onDelete: SetNull)
  action     AuditAction
  entityType String      // "Offer", "Project", "TimesheetEntry"...
  entityId   String?
  message    String
  diff       Json?
  createdAt  DateTime    @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

// =============================================================
// SETTINGS (clé/valeur générique pour paramètres globaux)
// =============================================================

model Setting {
  key   String @id
  value Json
  updatedAt DateTime @updatedAt
}

// Expérience professionnelle d'un candidat — alimente son CV interne Dasolabs.
// Modifiable par le candidat lui-même via le portail (/me) ou par un admin/recruteur.
model CandidateExperience {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  companyName String
  jobTitle    String?
  startDate   DateTime  @db.Date
  endDate     DateTime? @db.Date     // null = poste en cours
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([candidateId, startDate])
}

/// Expérience professionnelle d'un consultant interne (User). Structure
/// identique à CandidateExperience — les deux tables sont maintenues en
/// parallèle plutôt que fusionnées pour éviter une contrainte polymorphique
/// coûteuse et pour préserver les cascades delete simples.
model UserExperience {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName String
  jobTitle    String?
  startDate   DateTime  @db.Date
  endDate     DateTime? @db.Date     // null = poste en cours
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, startDate])
}

// Catalogue de compétences pré-configurées (autocomplete + cases à cocher)
// Les User.skills et Candidate.skills restent String[] : on peut toujours
// saisir une compétence hors catalogue (champ libre).
model Skill {
  id        String   @id @default(cuid())
  name      String   @unique
  category  String?  // "Backend", "Frontend", "Cloud", "Soft skills"...
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category, name])
}

// Groupe d'accès : ensemble nommé de permissions, indépendant du rôle métier.
// Le rôle (Consultant, Manager…) reste une étiquette de fonction.
// Le groupe (Admin, Lecture seule, Manager projet…) définit les vrais droits.
// Effective = group.permissions (si groupe assigné) OU role defaults, puis overrides.
model AccessGroup {
  id          String   @id @default(cuid())
  name        String   @unique     // "Administrateur", "Lecture seule"…
  description String?
  permissions String[]              // liste des codes Permission
  isSystem    Boolean  @default(false)  // groupes par défaut pré-créés
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Surcharge fine de permissions par utilisateur : grants explicites OU revokes
// au-dessus du groupe (ou du rôle si pas de groupe).
model UserPermissionOverride {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission String   // ex: "companies.write"
  granted    Boolean  // true = ajout explicite, false = retrait explicite
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, permission])
  @@index([userId])
}

// =============================================================
// CONSULTANCE — demandes de mission, candidats, applications, entretiens
// =============================================================

model MissionRequest {
  id              String        @id @default(cuid())
  reference       String        @unique          // DEM-2026-0001
  title           String
  description     String?
  status          MissionStatus @default(NEW)
  /// Stage CRM dans le kanban (NEW/QUALIFIED/PROPOSED/NEGOTIATING/WON/LOST/CANCELLED).
  /// Distinct du status métier MissionStatus qui n'a pas la même granularité.
  crmStage        String        @default("NEW")

  companyId       String
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  contactId       String?
  contact         Contact?      @relation("MissionContact", fields: [contactId], references: [id], onDelete: SetNull)
  // Société de portage / intermédiaire (ex: Randstad pour un consultant placé chez UCB)
  intermediaryCompanyId String?
  intermediaryCompany   Company? @relation("MissionRequestIntermediary", fields: [intermediaryCompanyId], references: [id], onDelete: SetNull)
  intermediaryContactId String?
  intermediaryContact   Contact? @relation("MissionRequestIntermediaryContact", fields: [intermediaryContactId], references: [id], onDelete: SetNull)
  ownerId         String?
  owner           User?         @relation("MissionOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  // Profil recherché
  requiredSkills  String[]      @default([])
  seniority       String?       // "Junior" | "Senior" | "Lead" | etc.
  workLocation    String?       // Remote / Hybrid / Onsite + ville
  startDate       DateTime?     @db.Date
  endDate         DateTime?     @db.Date
  estimatedDays   Int?
  targetDailyRate Decimal?      @db.Decimal(10, 2)
  maxDailyRate    Decimal?      @db.Decimal(10, 2)
  notes           String?
  closedAt        DateTime?
  lostReason      String?

  applications    MissionApplication[]
  offers          Offer[]
  /// Propositions consultant envoyées au client (une par consultant).
  /// Cf. modèle MissionProposal en bas de fichier.
  proposals       MissionProposal[]
  // Si la demande aboutit, une Mission concrète est exécutée
  executedMissions Mission[]    @relation("MissionRequestExecutions")

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([companyId])
  @@index([status])
  @@index([intermediaryCompanyId])
}

// =============================================================
// PROPOSITION CONSULTANT — offre envoyée au client depuis une
// demande de mission (MissionRequest) pour un consultant donné.
//
// Contient les dates de mission, le régime (jours/semaine), le TJM
// vendu et un snapshot des jours ouvrés calculés au moment de l'envoi
// (afin que le PDF reste stable même si les fériés belges sont
// recalculés plus tard, ou si les dates sont modifiées après envoi).
// =============================================================

enum MissionProposalStatus {
  DRAFT       // en préparation
  SENT        // envoyée au client
  ACCEPTED    // acceptée par le client
  REJECTED    // refusée par le client
  CANCELLED   // annulée par Dasolabs (ex. consultant plus dispo)
}

model MissionProposal {
  id               String                @id @default(cuid())
  reference        String                @unique          // PROP-2026-0001

  missionRequestId String
  missionRequest   MissionRequest        @relation(fields: [missionRequestId], references: [id], onDelete: Cascade)
  /// Pivot sur MissionApplication : la proposition est TOUJOURS générée
  /// pour un profil déjà présenté (candidat externe OU consultant interne).
  /// L'unique constraint garantit qu'une application n'a qu'une seule
  /// proposition en cours ; une nouvelle version doit écraser l'ancienne.
  applicationId    String                @unique
  application      MissionApplication    @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  ownerId          String?
  owner            User?                 @relation("ProposalOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  /// Période de mission proposée au client. Le budget est calculé sur
  /// ces dates avec la lib working-days (weekends + fériés belges déduits).
  startDate        DateTime              @db.Date
  endDate          DateTime              @db.Date
  /// Régime : 5 = temps plein, 4 = 4/5ème, 2.5 = mi-temps, valeur libre.
  workDaysPerWeek  Decimal               @default(5) @db.Decimal(3, 1)
  /// Inclure les fériés belges dans le calcul (les DÉDUIRE) ou pas.
  includeHolidays  Boolean               @default(true)
  /// Tarif journalier VENDU au client (HTVA, EUR).
  dailyRate        Decimal               @db.Decimal(10, 2)

  /// Snapshot calculé : jours ouvrés × ratio régime = jours facturables.
  /// Rempli à chaque save via recomputeProposalTotals(), affiché sur PDF.
  computedDays     Decimal               @default(0) @db.Decimal(8, 2)
  /// Snapshot : dailyRate × computedDays (HTVA).
  computedBudgetHt Decimal               @default(0) @db.Decimal(12, 2)

  /// Message d'accompagnement affiché sur le PDF (introduction).
  intro            String?
  /// Notes internes (pas sur le PDF client).
  internalNotes    String?

  sentAt           DateTime?
  decidedAt        DateTime?             // quand ACCEPTED ou REJECTED
  lostReason       String?

  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([missionRequestId])
}

model Candidate {
  id              String          @id @default(cuid())
  firstName       String
  lastName        String
  email           String?
  phone           String?
  linkedinUrl     String?
  // URL externe ou data URI (image base64 pour les uploads <200KB)
  photoUrl        String?
  city            String?
  source          String?         // LinkedIn, recommandation, plateforme...

  skills          String[]        @default([])
  yearsExperience Int?
  seniority       String?
  spokenLanguages String[]        @default([])

  // Tarifs (côté coût pour Dasolabs)
  dailyCost       Decimal?        @db.Decimal(10, 2)
  hourlyCost      Decimal?        @db.Decimal(10, 2)
  // Tarif minimum souhaité par le candidat (pour éviter les présentations à perte)
  minDailyRate    Decimal?        @db.Decimal(10, 2)
  /// Taux journalier facturable au client (HTVA, EUR). Affiché sur le CV
  /// et utilisé comme suggestion par défaut lors de la présentation. Peut
  /// être différent de minDailyRate (marge commerciale).
  dailyRate       Decimal?        @db.Decimal(10, 2)

  status          CandidateStatus @default(ACTIVE)
  availableFrom   DateTime?       @db.Date
  notes           String?

  ownerId         String?
  owner           User?           @relation("CandidateOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  // Si le candidat a été recruté → on conserve un lien fort vers son User
  convertedToUserId String?       @unique
  convertedToUser   User?         @relation("CandidatePromotion", fields: [convertedToUserId], references: [id], onDelete: SetNull)
  convertedAt       DateTime?

  // Compte d'accès au portail candidat (Dasolabs leur crée un User pour qu'ils
  // puissent compléter leur CV en self-service). Distinct de convertedToUserId
  // qui correspond au recrutement effectif.
  portalUserId      String?       @unique
  portalUser        User?         @relation("CandidatePortal", fields: [portalUserId], references: [id], onDelete: SetNull)

  applications    MissionApplication[]
  attachments     Attachment[]    @relation("CandidateAttachments")
  // Entretiens d'embauche Dasolabs (préliminaires, sans présentation client)
  hiringInterviews Interview[]    @relation("CandidateHiringInterviews")
  // Expériences professionnelles (CV) — alimentées par le candidat ou l'admin
  experiences     CandidateExperience[]
  // Simulations de package salarial rattachées à ce candidat
  salaryScenarios CandidateSalaryScenario[]
  // Tests techniques assignés
  testAssignments TestAssignment[] @relation("TestAssigneeCandidate")
  // Interactions de prospection (chasseuse de têtes)
  outreachInteractions OutreachInteraction[] @relation("CandidateOutreach")
  /// Type de contrat quand ce candidat est engagé chez Dasolabs :
  /// EMPLOYEE = salarié (apparaît dans /employees pour config paie),
  /// FREELANCE = sous-traitant (factures reçues comme SupplierInvoice).
  /// NULL = pas encore déterminé (comportement historique).
  contractType    ContractType?
  /// Paie configurée pour ce candidat (si contractType=EMPLOYEE).
  payrollEmployee PayrollEmployee? @relation("PayrollFromCandidate")

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([lastName, firstName])
  @@index([status])
  @@index([contractType])
}

// =============================================================
// SIMULATEUR DE PACKAGE — calcul du coût journalier d'un candidat
// à partir d'un brut mensuel + avantages (voiture, chèques-repas,
// éco-chèques, assurance groupe, hospi, GSM, frais nets, etc.).
// =============================================================
model CandidateSalaryScenario {
  id                        String      @id @default(cuid())
  candidateId               String?
  candidate                 Candidate?  @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  label                     String

  // Inputs salaire
  grossMonthly              Decimal     @db.Decimal(10, 2)
  monthsPerYear             Decimal     @default(13.92) @db.Decimal(5, 2)
  employerChargesPct        Decimal     @default(25)    @db.Decimal(5, 2)
  /// Régime hebdomadaire (5 = temps plein)
  workingDaysPerWeek        Decimal     @default(5)     @db.Decimal(3, 1)
  workingDaysPerYear        Int         @default(220)

  // Avantages
  carMonthlyTco             Decimal     @default(0) @db.Decimal(10, 2)
  mealVoucherEmployerPerDay Decimal     @default(0) @db.Decimal(6, 2)
  ecoVouchersAnnual         Decimal     @default(0) @db.Decimal(8, 2)
  groupInsurancePct         Decimal     @default(0) @db.Decimal(5, 2)
  /// Coût mensuel hospi + autres assurances (multiplié par 12 dans le calcul)
  hospitalInsuranceMonthly  Decimal     @default(0) @db.Decimal(8, 2)
  /// Coût mensuel GSM + internet (multiplié par 12 dans le calcul)
  phoneInternetMonthly      Decimal     @default(0) @db.Decimal(8, 2)
  netExpensesMonthly        Decimal     @default(0) @db.Decimal(8, 2)

  // Marge cible + TJM vendu pour comparaison
  targetMarginPct           Decimal     @default(35) @db.Decimal(5, 2)
  /// TJM réellement facturé au client (0 = pas encore vendu)
  soldDailyRate             Decimal     @default(0)  @db.Decimal(10, 2)

  // Outputs cachés (pour tri/filtrage rapide)
  totalAnnualCost           Decimal     @db.Decimal(12, 2)
  costPerDay                Decimal     @db.Decimal(10, 2)
  billableRate              Decimal     @db.Decimal(10, 2)

  notes                     String?
  createdById               String?
  createdBy                 User?       @relation("ScenarioCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt                 DateTime    @default(now())
  updatedAt                 DateTime    @updatedAt

  @@index([candidateId])
  @@index([createdAt])
}

model MissionApplication {
  id                 String              @id @default(cuid())
  missionRequestId   String
  missionRequest     MissionRequest      @relation(fields: [missionRequestId], references: [id], onDelete: Cascade)

  // Une application référence EXACTEMENT UN sujet : soit un candidat externe,
  // soit un consultant interne déjà chez Dasolabs.
  candidateId        String?
  candidate          Candidate?          @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  consultantId       String?
  consultant         User?               @relation("UserApplications", fields: [consultantId], references: [id], onDelete: Cascade)

  proposedDailyRate  Decimal?            @db.Decimal(10, 2)   // ce qu'on facturera au client
  dailyCost          Decimal?            @db.Decimal(10, 2)   // snapshot du coût à la présentation

  status             ApplicationStatus   @default(PRESENTED)
  presentedAt        DateTime            @default(now())
  decisionAt         DateTime?
  rejectedReason     String?
  notes              String?

  interviews         Interview[]
  offer              Offer?              @relation("OfferApplication")
  /// Proposition PDF envoyée au client sur ce profil (0 ou 1). L'existence
  /// d'une proposition + statut OFFER_SENT signifie que l'offre est en
  /// attente de décision client. Cascade delete si l'application disparaît.
  proposal           MissionProposal?
  // Une application SELECTED produit une Mission exécutée
  mission            Mission?            @relation("ApplicationMission")

  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  // Unicité au sein d'une demande, séparément par source. NULL ne participe pas
  // aux contraintes uniques en Postgres, donc on peut avoir candidate ou consultant.
  @@unique([missionRequestId, candidateId])
  @@unique([missionRequestId, consultantId])
  @@index([status])
}

model Interview {
  id             String                @id @default(cuid())
  // Une interview est SOIT rattachée à une présentation client (placement),
  // SOIT directement à un candidat (entretien d'embauche Dasolabs préliminaire).
  applicationId  String?
  application    MissionApplication?   @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  candidateId    String?
  candidate      Candidate?            @relation("CandidateHiringInterviews", fields: [candidateId], references: [id], onDelete: Cascade)
  scheduledAt    DateTime
  kind           InterviewKind         @default(VIDEO)
  interviewers   String?               // texte libre, plusieurs noms
  location       String?
  feedback       String?
  outcome        InterviewOutcome      @default(PENDING)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([applicationId, scheduledAt])
  @@index([candidateId, scheduledAt])
  @@index([scheduledAt])
}

// =============================================================
// MISSION (T&M / Consultance) — ENTITÉ DISTINCTE D'UN PROJET FORFAIT
// =============================================================
// Une Mission représente l'affectation contractualisée d'un consultant chez
// un client en mode T&M (time & material). Elle est totalement indépendante
// du modèle Project (qui reste pour le forfait, lignes, équipe, livrables).
model Mission {
  id                String                  @id @default(cuid())
  reference         String                  @unique          // MIS-2026-0001
  title             String

  // Source : la demande client à l'origine
  missionRequestId  String
  missionRequest    MissionRequest          @relation("MissionRequestExecutions", fields: [missionRequestId], references: [id], onDelete: Restrict)
  // Source : l'application sélectionnée (le candidat retenu)
  applicationId     String?                 @unique
  application       MissionApplication?     @relation("ApplicationMission", fields: [applicationId], references: [id], onDelete: SetNull)

  // Le consultant interne qui exécute la mission
  consultantId      String?
  consultant        User?                   @relation("MissionConsultant", fields: [consultantId], references: [id], onDelete: SetNull)
  // Le client final (où le consultant exécute la mission)
  companyId         String
  company           Company                 @relation("MissionCompany", fields: [companyId], references: [id], onDelete: Restrict)
  // Société de portage / intermédiaire (ex: Randstad). Optionnel.
  intermediaryCompanyId String?
  intermediaryCompany   Company? @relation("MissionExecIntermediary", fields: [intermediaryCompanyId], references: [id], onDelete: SetNull)
  intermediaryContactId String?
  intermediaryContact   Contact? @relation("MissionExecIntermediaryContact", fields: [intermediaryContactId], references: [id], onDelete: SetNull)

  // Conditions contractuelles
  startDate         DateTime                @db.Date
  endDate           DateTime                @db.Date
  actualEndDate     DateTime?               @db.Date
  estimatedDays     Int?
  dailyRate         Decimal                 @db.Decimal(10, 2)  // facturé client
  dailyCost         Decimal                 @db.Decimal(10, 2)  // payé / coût interne
  workLocation      String?
  billingFrequency  BillingFrequency        @default(MONTHLY)

  // Statut d'exécution
  status            MissionExecutionStatus  @default(PLANNED)

  notes             String?

  // Saisies & facturation
  timesheetEntries  TimesheetEntry[]
  planningEntries   PlanningEntry[]
  milestones        BillingMilestone[]
  expenseReports    ExpenseReport[]         @relation("MissionExpenseReports")
  leaveRequests     LeaveRequest[]          @relation("MissionLeaveRequests")

  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@index([consultantId, status])
  @@index([companyId])
  @@index([status, endDate])
  @@index([intermediaryCompanyId])
}

// =============================================================
// SUIVI INTERNE DES CONSULTANTS (employés Dasolabs)
// =============================================================
// Distinction claire :
//   - Candidate + MissionApplication + Interview = recrutement externe
//   - User (rôle CONSULTANT) + ConsultantReview    = suivi interne RH/Manager
model ConsultantReview {
  id             String                  @id @default(cuid())
  subjectId      String
  subject        User                    @relation("ReviewSubject",  fields: [subjectId],   references: [id], onDelete: Cascade)
  conductedById  String?
  conductedBy    User?                   @relation("ReviewConductor", fields: [conductedById], references: [id], onDelete: SetNull)
  scheduledAt    DateTime
  kind           ConsultantReviewKind    @default(CHECK_IN)
  // Mission/Projet rattaché si pertinent (ex: end-of-mission)
  projectId      String?
  project        Project?                @relation("ProjectReviews", fields: [projectId], references: [id], onDelete: SetNull)
  feedback       String?
  privateNotes   String?    // visible uniquement par les Admin/Manager
  goals          String?
  outcome        ConsultantReviewOutcome @default(SCHEDULED)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@index([subjectId, scheduledAt])
}

// =============================================================
// CASHFLOW — outil de trésorerie prévisionnelle
// =============================================================

enum RecurringFrequency {
  MONTHLY         // tous les mois (paymentMonths ignoré)
  QUARTERLY       // 4 fois/an
  SEMI_ANNUAL     // 2 fois/an
  ANNUAL          // 1 fois/an
  CUSTOM          // mois spécifiques via paymentMonths
}

enum CashflowStatus {
  PLANNED         // prévu
  PAID            // payé / encaissé
  SKIPPED         // annulé pour ce mois
}

enum CashflowKind {
  EXPENSE             // dépense réelle
  INCOME              // recette manuelle (en plus des BillingMilestones)
  COMMITMENT          // engagement signé (entre dans le cumul)
  SIMULATION          // simulation what-if DÉPENSE (exclu du cumul par défaut)
  SIMULATION_INCOME   // simulation what-if RECETTE (ex. mission consultant pas signée)
}

// =============================================================
// SUPPLIER INVOICES — mirror des factures fournisseurs reçues
// (via Peppol dans Skwarel) avec OCR pour pré-remplissage.
// =============================================================

enum SupplierInvoiceStatus {
  DRAFT          // OCR fait, pas encore validé par l'utilisateur
  PENDING        // validé, en attente de paiement
  PAID           // payé
  DISPUTED       // litige
  CANCELLED      // annulé
}

/// Catégorisation belge pour le calcul de la TVA déductible.
/// Le mapping (taux de déduction, case 81/82/83) est dans lib/belgian-vat-rules.ts.
/// CAR_xxx → 50 % par défaut (règle bénéfique PME, override possible)
/// RESTAURANT / HOTEL / REPRESENTATION / GIFT_HIGH → 0 % (non déductible)
/// HARDWARE_INVESTMENT / CAR_PURCHASE → case 83 (biens d'investissement)
/// SOFTWARE_SAAS / SUBCONTRACTING / TELECOM / PROFESSIONAL_SERVICES → case 82 (services divers)
/// OFFICE_SUPPLIES / HARDWARE_SMALL → case 81 (biens et services courants)
enum SupplierInvoiceCategory {
  CAR_PURCHASE
  CAR_LEASE
  CAR_FUEL
  CAR_MAINTENANCE
  CAR_INSURANCE
  RESTAURANT
  HOTEL
  OFFICE_RENT
  UTILITIES
  SOFTWARE_SAAS
  SUBCONTRACTING
  OFFICE_SUPPLIES
  HARDWARE_SMALL
  HARDWARE_INVESTMENT
  PROFESSIONAL_SERVICES
  TRAINING
  TELECOM
  GIFT_LOW
  GIFT_HIGH
  REPRESENTATION
  OTHER
}

model SupplierInvoice {
  id              String                @id @default(cuid())
  /// Fournisseur — soit un Company existant (FK), soit juste le nom (free text)
  supplierCompanyId String?
  supplierCompany   Company?            @relation("CompanySupplierInvoices", fields: [supplierCompanyId], references: [id], onDelete: SetNull)
  supplierName    String                // Nom tel qu'extrait du PDF (toujours rempli)
  /// Numéro de facture du fournisseur
  invoiceNumber   String?
  /// Date de facture
  invoiceDate     DateTime              @db.Date
  /// Date d'échéance
  dueDate         DateTime?             @db.Date
  amountHt        Decimal               @db.Decimal(12, 2)
  vatRate         Decimal               @default(21) @db.Decimal(5, 2)
  vatAmount       Decimal               @db.Decimal(12, 2)
  amountTtc       Decimal               @db.Decimal(12, 2)
  currency        String                @default("EUR")
  /// Catégorie d'achat pour la déduction TVA belge.
  /// La règle (taux de déduction, case 81/82/83) est dérivée dans lib/belgian-vat-rules.ts.
  category        SupplierInvoiceCategory @default(OTHER)
  /// Override du taux de déduction (0.0 à 1.0). Si null, la règle de category s'applique.
  vatDeductibleRateOverride Decimal? @db.Decimal(5, 2)
  /// PDF source (data URI base64 inline ou URL)
  pdfUrl          String?
  /// Payload OCR brut pour audit/debug
  ocrPayload      Json?
  status          SupplierInvoiceStatus @default(DRAFT)
  paidAt          DateTime?
  notes           String?
  /// Source d'import : "manual" (drop PDF) | "email" (webhook Mailgun) | "api"
  source          String                @default("manual")
  createdById     String?
  createdBy       User?                 @relation("SupplierInvoiceCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([status])
  @@index([invoiceDate])
  @@index([supplierCompanyId])
}

/// Singleton settings cashflow (solde initial). 1 seule ligne attendue.
model CashflowSettings {
  id              String   @id @default("singleton")
  startingBalance Decimal  @default(0) @db.Decimal(14, 2)
  /// Date à laquelle ce solde initial est valable (typiquement 1er jan de l'année courante)
  startingDate    DateTime @default(now()) @db.Date
  updatedAt       DateTime @updatedAt
  updatedById     String?
  updatedBy       User?    @relation("CashflowSettingsUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
}

/// Catalogue des dépenses (et revenus) récurrents
model RecurringExpense {
  id              String   @id @default(cuid())
  label           String
  category        String?
  /// Montant par défaut (peut être overridé par mois)
  defaultAmount   Decimal  @db.Decimal(12, 2)
  /// Si true, c'est une recette récurrente (loyer encaissé, abo SaaS encaissé, etc.) au lieu d'une dépense
  isIncome        Boolean  @default(false)
  frequency       RecurringFrequency @default(MONTHLY)
  /// Pour CUSTOM/QUARTERLY/etc : liste des mois (1-12) où la ligne tombe
  paymentMonths   Int[]    @default([])
  /// Bornes temporelles facultatives : la récurrence ne s'applique que dans
  /// l'intervalle [startDate, endDate]. Si null, illimité dans cette direction.
  startDate       DateTime? @db.Date
  endDate         DateTime? @db.Date
  isActive        Boolean  @default(true)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdById     String?
  createdBy       User?    @relation("RecurringExpenseCreator", fields: [createdById], references: [id], onDelete: SetNull)

  months          RecurringExpenseMonth[]

  @@index([category])
  @@index([isActive])
}

/// Entrée mensuelle d'une dépense récurrente : override du montant + statut paiement
model RecurringExpenseMonth {
  id                  String   @id @default(cuid())
  recurringExpenseId  String
  recurringExpense    RecurringExpense @relation(fields: [recurringExpenseId], references: [id], onDelete: Cascade)
  year                Int
  month               Int      // 1-12
  /// Si null, on utilise defaultAmount du parent
  amountOverride      Decimal? @db.Decimal(12, 2)
  status              CashflowStatus @default(PLANNED)
  paidAt              DateTime?
  notes               String?
  // Transactions bancaires rapprochées avec cette entrée mensuelle
  bankMatches         BankTransaction[] @relation("BankMatchRecurringMonth")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([recurringExpenseId, year, month])
  @@index([year, month])
  @@index([status])
}

// =============================================================
// NOTES DE FRAIS — consultants soumettent des dépenses pour remboursement
// =============================================================

enum ExpenseReportStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  PAID
}

enum ExpenseReportCategory {
  TRANSPORT
  MEAL
  ACCOMMODATION
  SUPPLIES
  SOFTWARE
  TRAINING
  OTHER
}

model ExpenseReport {
  id              String                @id @default(cuid())
  /// Auteur de la note (User Dasolabs)
  userId          String
  user            User                  @relation("ExpenseReportUser", fields: [userId], references: [id], onDelete: Cascade)
  /// Rattachement : au max UN de (mission, project, costCenter). Le form UI
  /// force ce choix mutuellement exclusif pour clarifier la comptabilité.
  missionId       String?
  mission         Mission?              @relation("MissionExpenseReports", fields: [missionId], references: [id], onDelete: SetNull)
  projectId       String?
  project         Project?              @relation("ProjectExpenseReports", fields: [projectId], references: [id], onDelete: SetNull)
  costCenterId    String?
  costCenter      CostCenter?           @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  /// Participants d'un repas d'affaires (comptabilité analytique + preuve).
  /// JSON array of { userId?: string, name: string } — les internes (User)
  /// sont référencés par leur id pour rester à jour ; les externes stockés
  /// en nom libre. Utile aussi pour les frais de représentation.
  attendees       Json?
  date            DateTime              @db.Date
  category        ExpenseReportCategory @default(OTHER)
  description     String
  amountHt        Decimal               @db.Decimal(10, 2)
  vatAmount       Decimal               @default(0) @db.Decimal(10, 2)
  vatRate         Decimal               @default(21) @db.Decimal(5, 2)
  amountTtc       Decimal               @db.Decimal(10, 2)
  currency        String                @default("EUR")
  /// Override du taux de déduction TVA (0.0 à 1.0). Si null, on applique la règle
  /// belge selon la category (lib/belgian-vat-rules.ts).
  vatDeductibleRateOverride Decimal? @db.Decimal(5, 2)
  /// URL ou data URI de la photo du ticket (base64 inline si petit)
  receiptUrl      String?
  /// Données extraites par OCR (Claude Vision) — JSON brut pour audit
  ocrPayload      Json?
  status          ExpenseReportStatus   @default(DRAFT)
  submittedAt     DateTime?
  approvedById    String?
  approvedBy      User?                 @relation("ExpenseReportApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt      DateTime?
  rejectionReason String?
  paidAt          DateTime?
  notes           String?
  /// Sortie cash planifiée créée à l'approbation (fin du mois de la
  /// dépense). Cascade delete si la note est supprimée.
  cashflowEntry   OneOffCashflowEntry? @relation("ExpenseCashflow")
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([userId, date])
  @@index([status])
  @@index([missionId])
  @@index([projectId])
}

// =============================================================
// SICK LEAVE — arrêts maladie déclarés par les consultants
// =============================================================
// Un consultant déclare son arrêt (période + certificat en PJ). Tant qu'on
// est dans la fenêtre [startDate, endDate], il est considéré comme malade
// (badge rouge, section dashboard). Pas de workflow d'approbation : c'est
// une déclaration factuelle avec preuve (certificat médical).

model SickLeave {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation("UserSickLeaves", fields: [userId], references: [id], onDelete: Cascade)
  startDate      DateTime  @db.Date
  /// Dernier jour d'absence inclus (fin de l'arrêt)
  endDate        DateTime  @db.Date
  /// Raison optionnelle laissée à l'utilisateur (grippe, RDV médical, etc.)
  reason         String?
  /// URL ou data URI du certificat médical (PDF/JPG/PNG scanné)
  certificateUrl String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId, startDate])
  @@index([startDate, endDate])
}

// =============================================================
// LEAVE REQUESTS — demandes de congés payés / RTT
// =============================================================
// Workflow simple : le consultant saisit une demande (DRAFT), la soumet
// (SUBMITTED), le manager approuve/refuse. Pour les consultants en mission
// on trace en plus si le client a accordé le congé côté planning.

enum LeaveRequestStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  CANCELLED
}

enum LeaveType {
  ANNUAL          // congé payé légal
  RTT             // réduction du temps de travail
  CARRIED_OVER    // congé reporté de l'année précédente
  UNPAID          // congé sans solde
  SPECIAL         // congé spécial (mariage, naissance, décès…)
  OTHER
}

/// Type de compteur (bucket) pour LeaveBalance : LÉGAUX / RTT / REPORT.
/// Distinct de LeaveType car LeaveType s'applique à une demande individuelle.
enum LeaveBalanceType {
  ANNUAL_LEGAL    // congé payé légal
  RTT             // RTT
  CARRIED_OVER    // report de l'année précédente
}

/// Solde par utilisateur × année × type. Utile pour :
///  - garder l'historique des quotas (temps partiel, ancienneté, etc.)
///  - permettre le rollover de fin d'année (report + reset)
///  - afficher 3 compteurs distincts sur /me et /leaves
model LeaveBalance {
  id        String            @id @default(cuid())
  userId    String
  user      User              @relation("UserLeaveBalances", fields: [userId], references: [id], onDelete: Cascade)
  year      Int
  type      LeaveBalanceType
  /// Quota accordé pour cette (année, type)
  entitled  Decimal           @db.Decimal(4, 1)
  /// Notes optionnelles (raison du quota spécial, etc.)
  notes     String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([userId, year, type])
  @@index([userId, year])
}

model LeaveRequest {
  id              String             @id @default(cuid())
  userId          String
  user            User               @relation("UserLeaveRequests", fields: [userId], references: [id], onDelete: Cascade)
  startDate       DateTime           @db.Date
  /// Dernier jour de congé inclus
  endDate         DateTime           @db.Date
  /// Nombre de jours ouvrés (calculé à la création, permet override manuel
  /// pour les demi-journées).
  days            Decimal            @db.Decimal(4, 1)
  type            LeaveType          @default(ANNUAL)
  reason          String?
  notes           String?
  status          LeaveRequestStatus @default(DRAFT)
  submittedAt     DateTime?
  approvedById    String?
  approvedBy      User?              @relation("LeaveRequestApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt      DateTime?
  rejectionReason String?

  // ─── Consultant en mission : trace l'accord côté client ───
  /// Mission active au moment de la demande (optionnel — auto-rempli si
  /// le consultant a une seule mission active à la période demandée).
  missionId       String?
  mission         Mission?           @relation("MissionLeaveRequests", fields: [missionId], references: [id], onDelete: SetNull)
  /// True si le consultant confirme avoir demandé le congé côté client
  /// (chef de projet mission) et l'avoir obtenu. Reste false pour les
  /// non-consultants ou missions non concernées.
  clientApproved  Boolean            @default(false)
  clientApprovalNotes String?

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([userId, startDate])
  @@index([status])
  @@index([startDate, endDate])
}

// =============================================================
// CRM — pipeline de prospection commerciale (avant Offer formelle)
// =============================================================

enum OpportunityStage {
  NEW            // identifié, pas encore qualifié
  QUALIFIED      // qualifié (besoin confirmé, budget pressenti)
  PROPOSED       // proposition envoyée
  NEGOTIATING    // en négociation
  WON            // gagné — transforme en Offer/Project
  LOST           // perdu
  CANCELLED      // annulé (par nous ou le client), pas un "vrai" perdu — masqué par défaut
}

model Opportunity {
  id              String           @id @default(cuid())
  title           String
  description     String?
  /// Type d'opportunité : CONSULTING (T&M) ou PROJECT (forfait).
  /// Réutilise l'enum OfferMode existant pour rester aligné avec l'aval (Offer/Project).
  kind            OfferMode        @default(CONSULTING)
  /// Société visée — désormais OBLIGATOIRE (doit exister en base avant)
  companyId       String?
  company         Company?         @relation("CompanyOpportunities", fields: [companyId], references: [id], onDelete: SetNull)
  /// Contact référent (du Company) — optionnel mais recommandé
  contactId       String?
  contact         Contact?         @relation("ContactOpportunities", fields: [contactId], references: [id], onDelete: SetNull)
  /// Champs libres conservés pour compatibilité (anciennes opps) — non saisis en UI
  prospectName    String?
  prospectEmail   String?
  prospectPhone   String?
  /// Owner commercial
  ownerId         String?
  owner           User?            @relation("OpportunityOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  stage           OpportunityStage @default(NEW)
  /// Valeur estimée HTVA (deal complet)
  estimatedValue  Decimal          @default(0) @db.Decimal(12, 2)
  /// Probabilité de gain en % (0-100)
  probability     Int              @default(20)
  /// Date prévisionnelle de closing
  expectedCloseAt DateTime?        @db.Date
  closedAt        DateTime?
  lostReason      String?
  notes           String?
  source          String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  activities      OpportunityActivity[]

  @@index([stage])
  @@index([ownerId])
  @@index([expectedCloseAt])
}

model OpportunityActivity {
  id            String      @id @default(cuid())
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?       @relation("OpportunityActivityUser", fields: [userId], references: [id], onDelete: SetNull)
  kind          String      // call, email, meeting, note, stage_change
  subject       String
  body          String?
  occurredAt    DateTime    @default(now())
  createdAt     DateTime    @default(now())

  @@index([opportunityId, occurredAt])
}

/// Dépense/revenu ponctuel ou engagement / simulation what-if
model OneOffCashflowEntry {
  id          String       @id @default(cuid())
  label       String
  category    String?
  amount      Decimal      @db.Decimal(12, 2)
  /// Date cible — seul le mois compte pour le cashflow mensuel
  date        DateTime     @db.Date
  kind        CashflowKind
  status      CashflowStatus @default(PLANNED)
  paidAt      DateTime?
  notes       String?
  /// Si plusieurs entrées partagent ce groupId, elles ont été créées en
  /// récurrence mensuelle ensemble — la grille les affiche en une seule
  /// ligne avec un montant par mois.
  recurrenceGroupId String?
  /// Lien vers une note de frais approuvée qui a généré cette sortie de
  /// cash automatiquement (planifiée fin de mois). Cascade delete pour
  /// que supprimer la note nettoie l'entrée cashflow.
  expenseReportId String?  @unique
  expenseReport   ExpenseReport? @relation("ExpenseCashflow", fields: [expenseReportId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  createdById String?
  createdBy   User?        @relation("OneOffCashflowCreator", fields: [createdById], references: [id], onDelete: SetNull)
  // Transactions bancaires rapprochées avec cette entrée one-off
  bankMatches BankTransaction[] @relation("BankMatchOneOff")

  @@index([date])
  @@index([kind, status])
  @@index([recurrenceGroupId])
}

/// Lien vers une application externe utilisée par Dasolabs (Hetzner, Vercel, GitHub, etc.).
/// Affichée sous forme de dalle cliquable dans la page /app-links.
/// L'édition (ajout/modif/suppression) est réservée aux admins.
model AppLink {
  id          String   @id @default(cuid())
  name        String
  url         String
  description String?
  /// Position d'affichage (plus petit = plus haut dans la grille).
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  createdBy   User?    @relation("AppLinkCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([position])
}

// =============================================================
// ONBOARDING — checklists d'arrivée par user, templatables par rôle
// =============================================================

/// Template de checklist d'onboarding. Plusieurs peuvent coexister, on choisit
/// celui correspondant au rôle du nouvel user (sinon le générique sans rôle).
model OnboardingTemplate {
  id            String                   @id @default(cuid())
  name          String                   @unique
  /// Rôle ciblé (null = template générique pour tout rôle non couvert)
  role          Role?
  description   String?
  active        Boolean                  @default(true)
  /// Décalages en jours des entretiens auto-créés depuis la startDate.
  /// Défaut [1, 30, 90, 180] = kick-off, mois 1, trimestre, semestre.
  reviewOffsets Int[]                    @default([1, 30, 90, 180])
  items         OnboardingTemplateItem[]
  onboardings   Onboarding[]
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
}

model OnboardingTemplateItem {
  id               String             @id @default(cuid())
  templateId       String
  template         OnboardingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  category         String             // "Administratif" / "IT" / "Formation" / "Intégration équipe"
  title            String
  description      String?
  /// Rôle "responsable par défaut" de l'item (qui doit le faire). Sera
  /// résolu à un user concret lors de l'instanciation si possible.
  defaultOwnerRole Role?
  /// Décalage en jours par rapport à la startDate de l'onboarding.
  /// Négatif = avant l'arrivée (ex: J-7 pour commander le laptop).
  daysOffset       Int                @default(0)
  position         Int                @default(0)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([templateId, position])
}

/// Instance d'onboarding pour un user concret. Créée auto à la création
/// du user (si un template matchant son rôle existe) ou manuellement.
model Onboarding {
  id          String             @id @default(cuid())
  /// Un seul onboarding actif par user — d'où le @unique.
  userId      String             @unique
  user        User               @relation("UserOnboarding", fields: [userId], references: [id], onDelete: Cascade)
  templateId  String?
  template    OnboardingTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  startDate   DateTime           @db.Date
  status      String             @default("IN_PROGRESS") // IN_PROGRESS / DONE / ARCHIVED
  notes       String?
  items       OnboardingItem[]
  createdById String?
  createdBy   User?              @relation("OnboardingCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([status])
}

model OnboardingItem {
  id           String     @id @default(cuid())
  onboardingId String
  onboarding   Onboarding @relation(fields: [onboardingId], references: [id], onDelete: Cascade)
  category     String
  title        String
  description  String?
  position     Int        @default(0)
  ownerId      String?
  owner        User?      @relation("OnboardingItemOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  dueDate      DateTime?  @db.Date
  done         Boolean    @default(false)
  doneAt       DateTime?
  doneById     String?
  doneBy       User?      @relation("OnboardingItemDoneBy", fields: [doneById], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([onboardingId, position])
  @@index([ownerId, done])
}

// =============================================================
// DOCUMENTS — DMS interne avec tags, expiration, versioning, liens entités
// =============================================================
//
// Stockage physique : disque local du VPS, monté en volume Docker sur
// /data/documents (override via env DOCS_STORAGE_PATH si besoin).
// Chaque fichier vit dans /data/documents/<documentId>/<originalName>.
// On stocke le chemin RELATIF dans storagePath ("<documentId>/<originalName>")
// — comme ça on peut bouger la racine sans casser les liens.
//
// Versioning : V1 a parentDocumentId=null, V2/V3/Vn pointent vers V1.id.
// La liste principale ne montre que les "anchors" (V1) — la fiche détail
// affiche toutes les versions.
model Document {
  id            String   @id @default(cuid())
  title         String
  originalName  String
  mimeType      String
  size          Int      // octets
  storagePath   String   // chemin relatif depuis DOCS_STORAGE_PATH
  description   String?
  tags          String[] @default([])
  expiresAt     DateTime? @db.Date

  // Liens optionnels vers entités
  companyId    String?
  company      Company? @relation("DocumentCompany", fields: [companyId], references: [id], onDelete: SetNull)
  projectId    String?
  project      Project? @relation("DocumentProject", fields: [projectId], references: [id], onDelete: SetNull)
  offerId      String?
  offer        Offer?   @relation("DocumentOffer",   fields: [offerId],   references: [id], onDelete: SetNull)
  consultantId String?
  consultant   User?    @relation("DocumentConsultant", fields: [consultantId], references: [id], onDelete: SetNull)

  // Versioning : V1 = parent=null, V2/V3/Vn = parent=V1.id
  parentDocumentId String?
  parentDocument   Document?  @relation("DocumentVersions", fields: [parentDocumentId], references: [id], onDelete: SetNull)
  versions         Document[] @relation("DocumentVersions")
  version          Int        @default(1)

  uploadedById String?
  uploadedBy   User?    @relation("DocumentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([companyId])
  @@index([projectId])
  @@index([offerId])
  @@index([consultantId])
  @@index([parentDocumentId])
  @@index([expiresAt])
  @@index([createdAt])
}

// =============================================================
// TESTS TECHNIQUES — évaluation candidats et consultants
//
// Cinq tests métier (ELEC, PLC, DATA, IT, CYBERSEC), question taguée
// difficulté (Junior → Expert) pour cartographier le niveau et pas juste
// scorer brut. Le répondant ne voit jamais son score ; l'admin voit le
// breakdown sur la fiche profil.
//
// Accès :
//   - Consultant interne : connecté Dasohub, onglet /me/tests
//   - Candidat externe   : lien magique unique (cuid) valide 14 jours
//     sans création de compte Dasohub
// =============================================================

enum TestDomain {
  ELEC_INDUSTRIAL
  PLC
  DATA_MANAGER
  IT_INDUSTRIAL
  CYBERSEC_INDUSTRIAL
  OTHER
}

enum TestDifficulty {
  JUNIOR
  MEDIOR
  SENIOR
  EXPERT
}

enum TestAssignmentStatus {
  PENDING       // assignation créée, pas commencée
  IN_PROGRESS   // au moins une réponse enregistrée
  COMPLETED     // soumis
  EXPIRED       // expiresAt dépassé sans soumission
}

model Test {
  id          String         @id @default(cuid())
  /// Plus @unique : on autorise plusieurs tests par domaine (ex. test PLC
  /// niveau junior et un autre niveau expert), et on a OTHER pour les
  /// thématiques hors des 5 domaines initiaux.
  domain      TestDomain
  title       String
  description String?
  isActive    Boolean        @default(true)
  questions   TestQuestion[]
  assignments TestAssignment[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model TestQuestion {
  id         String         @id @default(cuid())
  testId     String
  test       Test           @relation(fields: [testId], references: [id], onDelete: Cascade)
  position   Int
  text       String         @db.Text
  /// JUNIOR / MEDIOR / SENIOR / EXPERT — sert au breakdown du score sur fiche profil
  difficulty TestDifficulty @default(MEDIOR)
  /// 1 par défaut, ajustable si on veut surpondérer certaines questions
  points     Int            @default(1)
  /// True pour les mises en situation (cas pratique). Visible côté admin pour
  /// distinguer connaissance vs jugement.
  isScenario Boolean        @default(false)
  choices    TestChoice[]
  answers    TestAnswer[]

  @@unique([testId, position])
  @@index([testId])
}

model TestChoice {
  id         String       @id @default(cuid())
  questionId String
  question   TestQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  position   Int
  text       String       @db.Text
  isCorrect  Boolean      @default(false)
  answers    TestAnswer[]

  @@unique([questionId, position])
  @@index([questionId])
}

model TestAssignment {
  id            String                @id @default(cuid())
  testId        String
  test          Test                  @relation(fields: [testId], references: [id], onDelete: Cascade)
  // Soit consultant interne, soit candidat externe — exactement un des deux
  userId        String?
  user          User?                 @relation("TestAssigneeUser", fields: [userId], references: [id], onDelete: Cascade)
  candidateId   String?
  candidate     Candidate?            @relation("TestAssigneeCandidate", fields: [candidateId], references: [id], onDelete: Cascade)
  /// Lien magique unique pour l'accès candidat externe sans compte
  magicToken    String                @unique @default(cuid())
  status        TestAssignmentStatus  @default(PENDING)
  assignedAt    DateTime              @default(now())
  assignedById  String
  assignedBy    User                  @relation("TestAssignmentCreator", fields: [assignedById], references: [id])
  /// Par défaut +14 jours côté server action, modifiable à la création
  expiresAt     DateTime?
  submission    TestSubmission?

  @@index([userId])
  @@index([candidateId])
  @@index([status])
}

model TestSubmission {
  id           String         @id @default(cuid())
  assignmentId String         @unique
  assignment   TestAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  startedAt    DateTime       @default(now())
  completedAt  DateTime?
  /// Scores cumulés — cachés au répondant, visibles admin uniquement
  score        Int            @default(0)
  maxScore     Int            @default(0)
  /// Breakdown par niveau de difficulté pour cartographie de compétences
  scoreJunior  Int            @default(0)
  maxJunior    Int            @default(0)
  scoreMedior  Int            @default(0)
  maxMedior    Int            @default(0)
  scoreSenior  Int            @default(0)
  maxSenior    Int            @default(0)
  scoreExpert  Int            @default(0)
  maxExpert    Int            @default(0)
  /// Snapshot JSON des questions et choix au moment où le test a été
  /// commencé (premier saveAnswer). Permet d'afficher les bonnes réponses
  /// telles qu'à l'époque même si l'admin a édité les questions depuis.
  /// Structure : { questions: [{ id, position, text, difficulty, isScenario,
  /// points, choices: [{ id, position, text, isCorrect }] }] }
  questionsSnapshot Json?
  answers           TestAnswer[]
}

model TestAnswer {
  id           String         @id @default(cuid())
  submissionId String
  submission   TestSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  questionId   String
  question     TestQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  choiceId     String
  choice       TestChoice     @relation(fields: [choiceId], references: [id], onDelete: Cascade)
  answeredAt   DateTime       @default(now())

  @@unique([submissionId, questionId])
  @@index([submissionId])
}

// =============================================================
// INTÉGRATION BANCAIRE — GoCardless Bank Account Data (ex-Nordigen)
//
// Flow : l'utilisateur crée une BankConnection (requisition GoCardless)
// en autorisant l'accès à son compte ING via le portail bancaire. Les
// BankAccount et leur historique de BankTransaction sont ensuite
// synchronisés régulièrement. Les transactions sont rapprochées
// manuellement (ou avec suggestions heuristiques) contre les entrées
// existantes du cashflow (RecurringExpenseMonth, OneOffCashflowEntry)
// et contre les BillingMilestone pour les recettes clients.
// =============================================================

enum BankConnectionStatus {
  PENDING          // requisition créée, pas encore autorisée par l'utilisateur
  LINKED           // autorisation reçue, comptes récupérables
  EXPIRED          // consentement expiré (>90 jours par défaut GoCardless)
  ERROR            // erreur côté API
  REVOKED          // révoqué par l'utilisateur depuis sa banque
}

/// Représente une autorisation d'accès à une banque via GoCardless.
/// Un lien = une requisition = un token de consentement PSD2 (durée par
/// défaut 90 jours ; extensible à 180 chez certaines banques belges).
model BankConnection {
  id              String                @id @default(cuid())
  /// Institution GoCardless (ex. "ING_BBRUBEBB" pour ING BE)
  institutionId   String
  institutionName String
  /// ID de requisition GoCardless — clé pour tous les appels API
  requisitionId   String                @unique
  status          BankConnectionStatus  @default(PENDING)
  /// URL à visiter pour finaliser l'autorisation (générée par GoCardless)
  authorizationUrl String?
  /// Date d'expiration du consentement — si dépassée, il faut relancer
  /// le flow d'autorisation. GoCardless renvoie cette info à la création.
  expiresAt       DateTime?
  createdById     String?
  createdBy       User?                 @relation("BankConnectionCreator", fields: [createdById], references: [id], onDelete: SetNull)
  accounts        BankAccount[]
  lastSyncAt      DateTime?
  lastSyncError   String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([status])
}

/// Un compte bancaire concret exposé par une BankConnection. Une
/// requisition peut contenir plusieurs comptes (courant, épargne, ...).
model BankAccount {
  id              String            @id @default(cuid())
  connectionId    String
  connection      BankConnection    @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  /// ID du compte côté GoCardless (utilisé pour fetch les transactions)
  accountId       String            @unique
  iban            String?
  currency        String            @default("EUR")
  /// Nom / alias (souvent renvoyé par la banque, sinon on garde iban masqué)
  name            String?
  ownerName       String?
  transactions    BankTransaction[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

enum BankTransactionStatus {
  UNRECONCILED     // pas encore rapprochée
  RECONCILED       // liée à une entrée cashflow
  IGNORED          // exclue volontairement (ex. transfert interne)
}

/// Une transaction bancaire importée depuis GoCardless. Dédup sur
/// internalTransactionId (identifiant unique renvoyé par la banque, ou
/// hash déterministe qu'on calcule si absent).
model BankTransaction {
  id                    String                 @id @default(cuid())
  accountId             String
  account               BankAccount            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  /// ID interne côté banque/GoCardless — sert de clé de dédup.
  internalTransactionId String
  bookingDate           DateTime               @db.Date
  valueDate             DateTime?              @db.Date
  /// Montant SIGNÉ (négatif = débit, positif = crédit) en EUR.
  amount                Decimal                @db.Decimal(12, 2)
  currency              String                 @default("EUR")
  /// Nom du bénéficiaire / débiteur (variable selon signe)
  counterpartyName      String?
  counterpartyIban      String?
  /// Libellé de la transaction (memo / remittance information)
  remittanceInfo        String?
  status                BankTransactionStatus  @default(UNRECONCILED)
  /// Rapprochement — 0 ou 1 target parmi les 3 possibles (XOR souple :
  /// on n'enforce pas côté SQL car parfois une transaction couvre
  /// plusieurs items, mais l'UI aiguille sur un seul à la fois pour
  /// simplifier). Set côté server action au moment du rapprochement.
  matchedRecurringMonthId  String?
  matchedRecurringMonth    RecurringExpenseMonth? @relation("BankMatchRecurringMonth", fields: [matchedRecurringMonthId], references: [id], onDelete: SetNull)
  matchedOneOffId          String?
  matchedOneOff            OneOffCashflowEntry?   @relation("BankMatchOneOff", fields: [matchedOneOffId], references: [id], onDelete: SetNull)
  matchedMilestoneId       String?
  matchedMilestone         BillingMilestone?      @relation("BankMatchMilestone", fields: [matchedMilestoneId], references: [id], onDelete: SetNull)
  reconciledAt             DateTime?
  reconciledById           String?
  reconciledBy             User?                  @relation("BankReconciler", fields: [reconciledById], references: [id], onDelete: SetNull)
  /// Notes libres (raison d'ignore, commentaire de rapprochement...)
  notes                    String?
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt

  @@unique([accountId, internalTransactionId])
  @@index([status, bookingDate])
  @@index([matchedRecurringMonthId])
  @@index([matchedOneOffId])
  @@index([matchedMilestoneId])
}

// =============================================================
// PROSPECTION — outil de chasseuse de têtes
//
// Objectif : équiper le sourcing outbound (candidats consultants ET
// prospects clients). Chaque contact envoyé (LinkedIn, mail, tél)
// devient une OutreachInteraction avec statut, canal, contenu,
// prochaine action datée.
//
// La cible est polymorphe (via champs mutuellement exclusifs) :
//   - candidateId  : personne déjà dans la base des candidats
//   - contactId    : personne déjà dans la base des contacts (client)
//   - freeform*    : personne trouvée en cold outreach (LinkedIn URL,
//                    nom seul, entreprise, etc.) — pas encore importée
//
// Cette souplesse permet à la sourceuse de traquer 30-50 contacts/jour
// sans devoir d'abord créer une fiche complète pour chaque profil.
// =============================================================

enum OutreachDirection {
  OUTBOUND         // on contacte
  INBOUND          // on reçoit une candidature spontanée
}

enum OutreachChannel {
  LINKEDIN
  EMAIL
  PHONE
  MEETING
  OTHER
}

enum OutreachStatus {
  SENT              // message envoyé, en attente
  READ              // LinkedIn/email track shows read
  REPLIED_POSITIVE  // réponse positive (intéressé, à qualifier)
  REPLIED_NEGATIVE  // réponse négative (pas intéressé)
  NO_RESPONSE       // silence radio après relance(s)
  BOUNCED           // email rejeté / profil supprimé
}

enum OutreachPurpose {
  SOURCE_CANDIDATE  // on cherche à recruter cette personne
  SELL_TO_CLIENT    // on cherche à vendre nos services à cette personne
  OTHER
}

model OutreachTemplate {
  id           String           @id @default(cuid())
  name         String
  description  String?
  channel      OutreachChannel
  purpose      OutreachPurpose  @default(SOURCE_CANDIDATE)
  /// Objet (email uniquement)
  subject      String?
  /// Corps avec placeholders {{prenom}}, {{nom}}, {{entreprise}}, {{poste}}
  body         String
  isArchived   Boolean          @default(false)
  createdById  String?
  createdBy    User?            @relation("OutreachTemplateCreator", fields: [createdById], references: [id], onDelete: SetNull)
  interactions OutreachInteraction[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([channel, purpose, isArchived])
}

model OutreachInteraction {
  id             String              @id @default(cuid())
  /// La sourceuse qui a fait la démarche (typiquement toujours la même)
  ownerId        String
  owner          User                @relation("OutreachOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  direction      OutreachDirection   @default(OUTBOUND)
  channel        OutreachChannel
  purpose        OutreachPurpose

  // ─── Cible polymorphe (XOR côté applicatif, pas SQL) ───
  candidateId    String?
  candidate      Candidate?          @relation("CandidateOutreach", fields: [candidateId], references: [id], onDelete: SetNull)
  contactId      String?
  contact        Contact?            @relation("ContactOutreach", fields: [contactId], references: [id], onDelete: SetNull)
  /// Cible non-persistée : nom + entreprise + LinkedIn URL + email pour
  /// un cold outreach sans avoir à créer une fiche candidat/contact.
  freeformName        String?
  freeformCompany     String?
  freeformJobTitle    String?
  freeformLinkedinUrl String?
  freeformEmail       String?

  // ─── Contenu du message ───
  templateId     String?
  template       OutreachTemplate?   @relation(fields: [templateId], references: [id], onDelete: SetNull)
  subject        String?
  body           String?

  // ─── Statut et suivi ───
  status         OutreachStatus      @default(SENT)
  sentAt         DateTime            @default(now())
  respondedAt    DateTime?
  responseNote   String?

  // ─── Prochaine action datée ───
  /// Si null, pas de relance planifiée. Sinon apparaît dans le planning
  /// quotidien de la sourceuse et dans l'email digest matinal.
  nextActionAt   DateTime?           @db.Date
  nextActionNote String?
  nextActionDone Boolean             @default(false)

  notes          String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([ownerId, sentAt])
  @@index([status])
  @@index([nextActionAt, nextActionDone])
  @@index([candidateId])
  @@index([contactId])
}

// =============================================================
// PAYROLL — Employés Dasolabs avec leurs 3 sorties mensuelles
//
// Objectif : dans le cashflow, remplacer les N × 3 lignes (Salaire X,
// Précompte X, ONSS X pour chaque personne) par 3 lignes AGRÉGÉES
// (Salaires / Précompte pro / ONSS) sommées sur tous les employés
// actifs au mois M. L'ajout / le départ d'un employé se répercute
// automatiquement dans les prévisions.
//
// Les 3 montants correspondent aux 3 versements bancaires typiques
// que l'employeur belge fait chaque mois :
//  - monthlyNetPay          → au salarié (compte perso)
//  - monthlyWithholdingTax  → au fisc (précompte professionnel)
//  - monthlyOnss            → à l'ONSS (cotisations totales patronales
//                             + salariales versées à la source)
//
// PayrollEmployee est INDÉPENDANT du modèle User : un employé n'a pas
// forcément un compte ERP (ex. Marlène du sourcing), et un User n'est
// pas forcément un employé salarié (ex. consultants externes).
// =============================================================

/// Type de contrat pour un candidat/consultant Dasolabs.
/// Détermine si la personne apparaît dans la page /employees pour
/// configurer sa paie (salaire net, précompte, ONSS).
enum ContractType {
  EMPLOYEE     // salarié Dasolabs → apparaît dans /employees pour paie
  FREELANCE    // sous-traitant → pas de paie interne, factures reçues comme SupplierInvoice
}

model PayrollEmployee {
  id                    String    @id @default(cuid())
  firstName             String
  lastName              String
  role                  String?   // ex. "Sourceuse", "Consultant Data", "PMO"

  // ─── Lien optionnel vers la source (Candidat ou Consultant interne) ───
  /// Si la paie est configurée depuis un Candidat existant. Contrainte :
  /// un candidat n'a qu'une seule paie (unique). Cascade delete côté DB
  /// pour éviter les orphelins.
  candidateId           String?   @unique
  candidate             Candidate? @relation("PayrollFromCandidate", fields: [candidateId], references: [id], onDelete: Cascade)
  /// Si la paie est configurée depuis un Consultant interne (User).
  userId                String?   @unique
  user                  User?     @relation("PayrollFromUser", fields: [userId], references: [id], onDelete: Cascade)

  /// Date d'entrée effective (impact sur le premier mois pris en compte)
  startDate             DateTime  @db.Date
  /// Date de sortie effective. NULL = toujours en poste.
  /// Le cashflow arrête d'inclure l'employé le mois suivant la sortie.
  endDate               DateTime? @db.Date

  // ─── Les 3 sorties mensuelles (EUR, valeurs positives) ───
  monthlyNetPay         Decimal   @default(0) @db.Decimal(10, 2)
  monthlyWithholdingTax Decimal   @default(0) @db.Decimal(10, 2)
  monthlyOnss           Decimal   @default(0) @db.Decimal(10, 2)

  // ─── Contexte (indicatif, pas repris dans le cashflow) ───
  /// Salaire brut mensuel de référence
  monthlyGrossReference Decimal?  @db.Decimal(10, 2)
  /// Nb de mois versés / an (13.92 par défaut BE, tient compte du 13e + double pécule)
  monthsPerYear         Decimal   @default(13.92) @db.Decimal(5, 2)
  notes                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([startDate, endDate])
}

/// Type de sortie mensuelle payroll (les 3 lignes agrégées du cashflow).
enum PayrollKind {
  NET_PAY           // Salaires nets — vireés aux employés
  WITHHOLDING_TAX   // Précompte professionnel — versé au fisc
  ONSS              // Cotisations sociales — versées à l'ONSS
}

/// Une case (mois × type) du cashflow payroll. Permet de marquer chaque
/// versement PAID individuellement (utile pour clôturer le passé).
/// Le MONTANT vient toujours du calcul agrégé sur PayrollEmployee actifs
/// — sauf si amountOverride est renseigné (rare : correction d'écart).
model PayrollMonth {
  id             String         @id @default(cuid())
  year           Int
  month          Int            // 1-12
  kind           PayrollKind
  status         CashflowStatus @default(PLANNED)
  paidAt         DateTime?
  /// Montant réel constaté (si différent du calculé). Rare — utilisé
  /// pour absorber les micro-écarts constatés à la clôture.
  amountOverride Decimal?       @db.Decimal(12, 2)
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([year, month, kind])
  @@index([status])
}
